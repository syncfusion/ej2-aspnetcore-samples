@page
@model EJ2CoreSampleBrowser.Pages.Sankey.DefaultModel
@using Syncfusion.EJ2

@section ControlsSection{
    <div class="control-section" align="center">
        <!-- Syncfusion Sankey Tag Helper -->
        <ejs-sankey id="energy-sankey"
                    width="90%"
                    height="550"
                    background="transparent"
                    title="California Energy Consumption in 2023"
                    subTitle="Source: Lawrence Livermore National Laboratory" load="onSankeyLoad" >

            <e-sankey-margin left="20" right="20" top="20" bottom="20"></e-sankey-margin>

            <!-- Nodes -->
            <e-sankey-nodes>
                @foreach (var node in Model.Nodes)
                {
                    <e-sankey-node id="@node.Id" color="@node.Color" offset="@(node.Offset ?? 0)"></e-sankey-node>
                }
            </e-sankey-nodes>

            <!-- Links -->
            <e-sankey-links>
                @foreach (var link in Model.Links)
                {
                    <e-sankey-link sourceId="@link.SourceId" targetId="@link.TargetId" value="@link.Value"></e-sankey-link>
                }
            </e-sankey-links>

            <!-- Styling -->
            <e-sankey-nodesettings width="25" padding="5" opacity="1"></e-sankey-nodesettings>
            <e-sankey-linksettings opacity="0.6" curvature="0.55" colorType="Source"></e-sankey-linksettings>

            <!-- Labels -->
            <e-sankey-labelsettings visible="true"></e-sankey-labelsettings>

            <!-- Tooltip & Legend -->
            <e-sankey-tooltipsettings enable="true"
                                      nodeFormat="${name}: ${value} TBtu"
                                      linkFormat="${start.name}: ${start.out} TBtu → ${target.name}: ${target.in} TBtu">
            </e-sankey-tooltipsettings>
            <e-sankey-legendsettings visible="true" position="Bottom" itemPadding="8"></e-sankey-legendsettings>
        </ejs-sankey>
    </div>
}


  <script>
    function onSankeyLoad(args) {
      var isMobile = ej.base.Browser.isDevice;

      // Theme handling (same as your JS)
      var t = location.hash.split('/')[1] || 'Tailwind3';
      args.chart.theme = (t.charAt(0).toUpperCase() + t.slice(1))
        .replace(/-dark/i, 'Dark').replace(/light/i, 'Light')
        .replace(/contrast/i, 'Contrast').replace(/-highContrast/i, 'HighContrast');

      // Per-sample mobile tweaks
      if (args.chart.element.id === 'energy-sankey') {
        args.chart.height = isMobile ? '600' : '550';
        args.chart.labelSettings.visible = isMobile ? false : true;
        args.chart.tooltip.linkFormat = isMobile ? '${start.name}: ${start.out} TBtu<br/>→ ${target.name}: ${target.in} TBtu' : '${start.name}: ${start.out} TBtu → ${target.name}: ${target.in} TBtu';
      }
    }
  </script>


<style>
  #control-container { padding: 0 !important; }
</style>

@section Meta{
    <meta name="description" content="Interactive Sankey diagram of California energy consumption (2023) in TBtu, showing flows from sources to sectors, energy services, and rejected energy.">
}

@section ActionDescription{
    <p>
        Explore California’s 2023 energy consumption in TBtu (Trillion British Thermal Units) with an interactive Sankey chart based on Lawrence Livermore National Laboratory data. Follow energy flows from generation sources to Residential, Commercial, Industrial, and Transportation sectors, highlighting useful energy services versus rejected energy.
    </p>
}
@section Description{
    <p>
        This Sankey chart illustrates energy flow across sources, carriers, and usage sectors,
        with labeled nodes and interactive tooltips that reveal detailed link and value information.
    </p>

    <p><strong>Key features:</strong></p>
    <ul>
        <li>Configure nodes to represent energy sources and consumption sectors</li>
        <li>Define links to trace energy flow from generation through end use</li>
        <li>Enable tooltips for exploring individual flow values and relationships</li>
        <li>Hover over nodes or links for deeper insight into the energy distribution pattern</li>
    </ul>
}

@section Title{
    <title>ASP.NET Core Sankey - California Energy Consumption 2023 | Syncfusion Demos</title>
}

@section Header{
    <h1 class='sb-sample-text'>Sankey: California Energy Consumption (2023)</h1>
}