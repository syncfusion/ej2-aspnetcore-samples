                    <e-grid-column field="SubTotal" headerText="Sub Total" width="110" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})" format="C2" textAlign="Right" editType="NumericEdit"></e-grid-column>
                    <e-grid-column field="TaxAmount" headerText="Tax Amount" width="110" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})" format="C2" textAlign="Right" editType="NumericEdit"></e-grid-column>
                    <e-grid-column field="ShipFee" headerText="Ship Fee" width="120" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})" format="C2" textAlign="Right" editType="NumericEdit"></e-grid-column>
                    <e-grid-column field="TotalAmount" headerText="Total Amount" width="120" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})" format="C2" textAlign="Right" editType="NumericEdit"></e-grid-column>
