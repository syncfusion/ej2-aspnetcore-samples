    <div class="control-section">
        <ejs-grid id="BatchEdit" dataSource="@Model.datasource" height="400" clipMode="EllipsisWithTooltip" allowSorting="true" allowFiltering="true" toolbar="@(new List<string>() { "Add","Delete","Update","Cancel", "Undo", "Redo" })" allowPaging="true" cellEdit="cellEdit" beforeBatchSave="beforeBatchSave">
            <e-grid-editSettings allowAdding="true" allowDeleting="true" allowEditing="true" mode="Batch" enableUndoRedo="true"></e-grid-editSettings>
            <e-grid-pagesettings pageCount="5" ></e-grid-pagesettings>
            <e-grid-filterSettings type="CheckBox"></e-grid-filterSettings>
            <e-grid-selectionSettings mode="Cell" type="Multiple"></e-grid-selectionSettings>
            <e-grid-aggregates>
                <e-grid-aggregate>
                    <e-aggregate-columns>
                        <e-aggregate-column field="VendorA" type="Sum" format="N"
                            footerTemplate="Total: ${Sum}">
                        </e-aggregate-column>
                        <e-aggregate-column field="VendorB" type="Sum" format="N"
                            footerTemplate="Total: ${Sum}">
                        </e-aggregate-column>
                        <e-aggregate-column field="VendorC" type="Sum" format="N"
                            footerTemplate="Total: ${Sum}">
                        </e-aggregate-column>
                        <e-aggregate-column field="VendorD" type="Sum" format="N"
                            footerTemplate="Total: ${Sum}">
                        </e-aggregate-column>
                    </e-aggregate-columns>
                </e-grid-aggregate>
            </e-grid-aggregates>
            <e-grid-columns>
                <e-grid-column field="ID" headerText="ID" width="120" textAlign="Right" isPrimaryKey="true" validationRules="@(new { required = true })"></e-grid-column>
                <e-grid-column field="Product" headerText="Product Name" width="180" template="#categoryDetail" editType="dropdownedit" defaultValue=@("MacBook Pro") validationRules="@(new { required = true })"></e-grid-column>
                <e-grid-column field="VendorA" headerText="Vendor A (units)" width="160" textAlign="Right" editType="numericedit" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})"></e-grid-column>
                <e-grid-column field="VendorB" headerText="Vendor B (units)" width="160" textAlign="Right" editType="numericedit" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})"></e-grid-column>
                <e-grid-column field="VendorC" headerText="Vendor C (units)" width="160" textAlign="Right" editType="numericedit" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})"></e-grid-column>
                <e-grid-column field="VendorD" headerText="Vendor D (units)" width="160" textAlign="Right" editType="numericedit" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})"></e-grid-column>
                <e-grid-column field="UnitPrice" headerText="Price (per unit)" width="160" textAlign="Right" format="C2" editType="numericedit" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})" validationRules="@(new { required = true, min = 1 })"></e-grid-column>
            </e-grid-columns>
        </ejs-grid>
