@page
@model EJ2CoreSampleBrowser.Pages.AIAssistView.ThinkingModel
@using Syncfusion.EJ2
@using System.Text.Json;

@section ControlsSection {
    <div class="control-section">
        <div class="thinking-aiassistview">
            <ejs-aiassistview id="thinkingAssistView" 
                              promptSuggestions="@Model.PromptSuggestionData" 
                              bannerTemplate="#bannerContent" 
                              promptRequest="onPromptRequest"
                              enableStreaming="true"
                              created="onCreated">
            </ejs-aiassistview>
        </div>
    </div>
}

@section PreScripts{
    <script>
        var thinkingAIAssistView;
        var baseURL = window.baseurl;

        function onCreated() {
            var assistEle = document.getElementById('thinkingAssistView');
            thinkingAIAssistView = ej.base.getInstance(assistEle, ejs.interactivechat.AIAssistView);
        }

        async function onPromptRequest(args) {
            var context = this;
            thinkingAIAssistView = this;
            var partialThinkingBlocks = { blockType: 'thinking', title: 'Thinking', collapsible: true, collapsed: true, isActive: true, stages: [ { status: 'inprogress', content: 'Analyzing your request to deliver the most relevant response' } ] };
            var finalThinkingBlocks = { blockType: 'thinking', title: 'Thinking', collapsible: true, collapsed: true, isActive: false, stages: [ { status: 'completed', content: 'Analyzing your request to deliver the most relevant response' }, { status: 'completed', content: 'Done' } ] };
            context.addPromptResponse({ blocks: [ partialThinkingBlocks ] }, false);
            try {
                const userID = await window.fingerPrint();
                if (!userID) {
                    return 'Failed to generate user ID. Please try again later.';
                }
                const abortController = new AbortController();
                const response = await fetch(baseURL + '/api/AI/Stream', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authentication': userID
                    },
                    body: JSON.stringify({
                        message: args.prompt
                    }),
                    signal: abortController.signal
                });

                if (!response.ok) {
                    let text = await response.text();
                    let errorData;
                    try {
                        errorData = JSON.parse(text);
                    } catch (e) {
                        errorData = { error: 'HTTP Error ' + response.status + ': ' + text };
                    }
                    throw new Error(errorData.error || ('HTTP Error ' + response.status));
                }

                const reader = response.body.getReader();
                const decoder = new TextDecoder();
                let fullText = '';

                while (true) {
                    const { done, value } = await reader.read();
                    if (done) {
                        context.addPromptResponse({ blocks: [ finalThinkingBlocks ], response: fullText || "We could not reach the AI service; please try again later." });
                        break;
                    }
                    fullText += decoder.decode(value, { stream: true });
                }
                return fullText;
            } catch (error) {
                if (error.name === 'AbortError') {
                    return;
                } else if (error.message && error.message.indexOf('token limit') !== -1) {
                    context.addPromptResponse({ response: error.message });
                }
                context.addPromptResponse({ response: "We could not reach the AI service; please try again later." });
            }
        }
    </script>

    <script id="bannerContent" type="text/x-jsrender">
        <div class="banner-content">
            <div class="e-icons e-brain"></div>
            <h3>💭 Thinking Support</h3>
            <i>Break down complex problems and think through decisions.</i>
        </div>
    </script>
}

<style>
    .thinking-aiassistview {
        height: 600px;
        width: 60vw;
        margin: 0 auto;
    }

    .thinking-aiassistview .banner-content .e-brain:before {
        font-size: 35px;
    }

    .thinking-aiassistview .banner-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        height: 330px;
        text-align: center;
    }

    @@media only screen and (max-width: 750px) {
        .thinking-aiassistview {
            width: 100%;
        }
    }
</style>

@section Meta {
    <meta name="description" content="This example demonstrates the chain of thoughts feature in ASP.NET Core AIAssistView control. Explore here for more details." />
}

@section ActionDescription {
    <div id="action-description">
        <p>This sample demonstrates the thinking support and chain of thoughts feature of the AI AssistView control. Users can see the AI's reasoning process through multiple thinking stages.</p>
    </div>
}

@section Description {
    <div id="description">
        <p>In this example, the <a target="_blank" href="https://help.syncfusion.com/cr/aspnetcore-js2/Syncfusion.EJ2.InteractiveChat.AIAssistView.html#Syncfusion_EJ2_InteractiveChat_AIAssistView_BannerTemplate">bannerTemplate</a> customizes the banner content with a thinking icon. The <a target="_blank" href="https://help.syncfusion.com/cr/aspnetcore-js2/Syncfusion.EJ2.InteractiveChat.AIAssistView.html#Syncfusion_EJ2_InteractiveChat_AIAssistView_PromptSuggestions">promptSuggestions</a> property provides AI prompt suggestions to the user, and the <a target="_blank" href="https://help.syncfusion.com/cr/aspnetcore-js2/Syncfusion.EJ2.InteractiveChat.AIAssistView.html#Syncfusion_EJ2_InteractiveChat_AIAssistView_PromptRequest">promptRequest</a> event handles prompt requests. The component demonstrates the AI generated thinking blocks with multiple stages showing the thought process, including understanding requests, selecting components, designing layouts, and finalizing outputs.</p>
    </div>
}
