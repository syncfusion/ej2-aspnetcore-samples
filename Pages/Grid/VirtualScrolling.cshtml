    <div class="control-section">
        <div class="row">
            <table>
                <tr>
                    <td style="padding:15px">
                        <span>
                            <ejs-button id="generate" cssClass="e-info" content="Load 100K Data"></ejs-button>
                            <span id="popup">
                                <span id="gif" class="image"></span>
                            </span>
                        </span>
                        
                    </td>
                    <td>
                        <span style="padding-left:630px; " id="performanceTime">Time Taken: 0 ms</span>
                    </td>
                </tr>
            </table>
           

        </div>

        <div>
            <ejs-grid id="VirtualGrid" clipMode="EllipsisWithTooltip" height="600" rowHeight="50" dataBound="hide" load="load" enableVirtualization="true" enableColumnVirtualization="true" toolbar="@(new List<string>() { "Add", "Edit", "Delete", "Update", "Cancel" })">
                <e-grid-editSettings allowAdding="true" allowDeleting="true" allowEditing="true"></e-grid-editSettings>
                <e-grid-columns>
