        padding: 4px 8px;
        border-radius: 4px;
        text-align: center;
        font-size: 12px;
        font-weight: 500;
        width: 100px;
        line-height: 2;
    }

    .rg-badge-status[data-status="Running"] {
        background: #66bb6a;
        color: white;
    }

    .rg-badge-status[data-status="Stopped"] {
        background: #ef5350;
        color: white;
    }

    .rg-badge-status[data-status="Degraded"] {
        background: #ffb74d;
        color: white;
    }

    .rg-badge-status[data-status="Maintenance"] {
        background: #0277bd;
        color: white;
    }

    .rg-badge-priority[data-priority="Low"] {
        background-color: #ccffcc;
        color: #00cc00;
    }

    .rg-badge-priority[data-priority="High"] {
        background-color: #ffe5cc;
        color: #cc6600;
    }

    .rg-badge-priority[data-priority="Critical"] {
        background-color: #ffcccc;
        color: #cc0000;
    }

    .rg-compliance {
        width: 100px;
        height: 12px;
        background: #f3f4f6;
        border-radius: 20px;
