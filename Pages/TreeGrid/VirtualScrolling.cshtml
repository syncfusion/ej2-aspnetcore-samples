    }

    .rg-region[data-region="South America"] .rg-region-flag {
        background-image: url('data:image/svg+xml;utf8,<svg width="20" height="14" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="14" fill="%23009739"/><path d="M10,1 L18,7 L10,13 L2,7 Z" fill="%23FEDD00"/><circle cx="10" cy="7" r="2.5" fill="%23002776"/></svg>');
    }

    .rg-region-flag {
        background-image: url('data:image/svg+xml;utf8,<svg width="20" height="14" viewBox="0 0 20 14" xmlns="http://www.w3.org/2000/svg"><rect width="20" height="14" fill="%236b7280" rx="2"/><circle cx="10" cy="7" r="4" fill="none" stroke="%23fff" stroke-width="0.8"/><path d="M10,3 Q12,7 10,11 M10,3 Q8,7 10,11 M6,7 L14,7" stroke="%23fff" stroke-width="0.8" fill="none"/></svg>');
