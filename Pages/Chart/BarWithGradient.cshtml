@page
@model EJ2CoreSampleBrowser.Pages.Chart.BarWithGradientModel
@using Syncfusion.EJ2

@{
    var gradient = new Syncfusion.EJ2.Charts.ChartLinearGradient
    {
        X1 = 0,
        Y1 = 0,
        X2 = 1,
        Y2 = 0,
        GradientColorStop = new List<Syncfusion.EJ2.Charts.ChartGradientColorStop>
        {
            new Syncfusion.EJ2.Charts.ChartGradientColorStop { Color = "#1a9fd4", Offset = 0, Opacity = 1 },
            new Syncfusion.EJ2.Charts.ChartGradientColorStop { Color = "#9b4dca", Offset = 50, Opacity = 1 },
            new Syncfusion.EJ2.Charts.ChartGradientColorStop { Color = "#f95d8f", Offset = 100, Opacity = 1 }
        }
    };
}

@section ControlsSection {
    <div class="control-section" align="center">
        <ejs-chart id="gradientBarChart" load="load" title="Leading Revenue Drivers in India: 2024 Rankings" subTitle="Source: Wikipedia (Forbes 2024) | Revenue in USD Billions" style="display:block; text-align:center">
            <e-chart-chartarea>
                <e-chartarea-border width="0"></e-chartarea-border>
            </e-chart-chartarea>
            <e-chart-tooltipsettings enable="true" header="" format="${point.x}: <b>${point.y} B</b>">
            </e-chart-tooltipsettings>
            <e-chart-legendsettings visible="false"></e-chart-legendsettings>
            <e-chart-primaryxaxis valueType="@Syncfusion.EJ2.Charts.ValueType.Category" edgeLabelPlacement="@Syncfusion.EJ2.Charts.EdgeLabelPlacement.Shift" enableWrap="true" maximumLabelWidth="100">
                <e-majorgridlines width="1"></e-majorgridlines>
                <e-majorticklines width="0"></e-majorticklines>
                <e-linestyle width="0"></e-linestyle>
            </e-chart-primaryxaxis>
            <e-chart-primaryyaxis visible="false">
            </e-chart-primaryyaxis>
            <e-series-collection>
                <e-series dataSource="@Model.ChartPoints" xName="Company" yName="Revenue" name="Revenue" linearGradient="@gradient"
                          type="@Syncfusion.EJ2.Charts.ChartSeriesType.Bar" columnWidth="0.75" columnSpacing="0.25">
                    <e-series-cornerradius topLeft=10 topRight=10 bottomLeft=10 bottomRight=10></e-series-cornerradius>
                    <e-series-marker visible="false">
                        <e-series-datalabel visible="true" position="@Syncfusion.EJ2.Charts.LabelPosition.Outer" format="{value} B"></e-series-datalabel>
                    </e-series-marker>
                </e-series>
            </e-series-collection>
        </ejs-chart>
    </div>
    <script src="~/scripts/chart/theme-color.js"></script>
    <script>
        function load(args) {
            loadChartTheme(args);
            args.chart.width = ej.base.Browser.isDevice ? "100%" : "90%";
        }
    </script>
}
@*custom code start*@
@section Scripts {
}

<style>
    #control-container {
        padding: 0px !important;
    }
</style>

@section Meta {
    <meta name="description" content="This example demonstrates the Bar in ASP.NET Core Chart control. Explore here for more details." />
}
@*custom code end*@

@section ActionDescription {
    <p>
        This example visualizes the top revenue-generating companies in India for 2024. A horizontal bar chart with a left-to-right color gradient 
        is used to highlight each company's revenue in USD Billions. Company names appear on the left axis, and revenue values are displayed at the 
        end of each bar. Companies are ordered by revenue to emphasize ranking and relative contribution. Compare bar lengths to quickly identify the top 
        contributors among India's leading corporations.
    </p>
}

@section Description {
    <p>
        In this example, you can see how to render and configure a horizontal bar chart with a linear gradient fill using the
        <code>linearGradient</code> property of the series. The gradient is applied horizontally from left to right with multiple color stops
        to create smooth color transitions across all bars, visually emphasizing the revenue comparison.
    </p>
    <p>
        <code>Tooltip</code> is enabled in this example. To see the tooltip in action, hover over a bar or tap on a
        bar on touch-enabled devices.
    </p>
    <p>
        More information about the bar series can be found in this
        <a target="_blank" href="https://ej2.syncfusion.com/aspnetcore/documentation/chart/chart-types/bar" aria-label="Navigate to the documentation for Bar Charts in ASP.NET Core Chart control">documentation section</a>.
    </p>
}

@section Title {
    <title>ASP.NET Core Chart Bar with Gradient Example - Syncfusion Demos</title>
}

@section Header {
    <h1 class='sb-sample-text'>Example of Bar Chart with Gradient in ASP.NET Core Chart Control</h1>
}