    <PackageReference Include="Syncfusion.AspNetCore.CircularGauge" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.Diagram" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.DropDowns" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.FileManager" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.Gantt" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.Grid" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.HeatMap" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.ImageEditor" Version="34.1.29" />
    <PackageReference Include="Syncfusion.AspNetCore.InPlaceEditor" Version="34.1.29" />
