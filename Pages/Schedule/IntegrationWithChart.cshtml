@page
@model EJ2CoreSampleBrowser.Pages.Schedule.SchedulerWithChartModel
@using Syncfusion.EJ2
@using Syncfusion.EJ2.Schedule
@using Syncfusion.EJ2.Charts
@using Syncfusion.EJ2.DropDowns

@section ControlsSection {

	<div class="col-lg-12 schedule-with-chart control-section">
		<div class="content-wrapper">
			<div class="modern-layout" style="display:flex; gap:10px;">

				<div class="scheduler-wrapper">
					<ejs-schedule id="Schedule" height="650px" width="100%" selectedDate="new DateTime(2026,1,12)"
								  allowOverlap="false" currentView="TimelineMonth" resourceHeaderTemplate="#resourceTemplate"
								  headerIndentTemplate="#headerIndentTemplate" actionComplete="onActionComplete">
						<e-schedule-views>
							<e-schedule-view option="TimelineMonth"></e-schedule-view>
						</e-schedule-views>
						<e-schedule-group resources="@(new string[] { "TruckDetails" })"
										  headerTooltipTemplate="#tooltipTemplate"></e-schedule-group>
						<e-schedule-resources>
							<e-schedule-resource field="DriverID" name="TruckDetails" dataSource="@Model.driversMaster"
												 textField="driver" idField="id" colorField="color"></e-schedule-resource>
						</e-schedule-resources>
						<e-schedule-eventsettings dataSource="@Model.events"></e-schedule-eventsettings>
					</ejs-schedule>
				</div>

				<div id="chart-container" class="chart-section">
					<div class="chart-header">
						<h4 class="chart-title">Analytics</h4>

						<div class="dropdown-wrapper">
							<ejs-dropdownlist id="chart-ddl" value="@("tripcount")" change="onModeChange" dataSource="@(new List<object> {
									new { text = "Trip Count", value = "tripcount" },
									new { text = "Truck Capacity", value = "capacity" },
									new { text = "Longest Trips", value = "longest" }
								})">
								<e-dropdownlist-fields text="text" value="value"></e-dropdownlist-fields>
							</ejs-dropdownlist>
						</div>
					</div>

					<div class="chart-area">
						<ejs-chart id="chart" load="load" height="500px" title="Trip Count" pointRender="onPointRender">

							<e-chart-primaryxaxis valueType="Category" interval="1" labelRotation="-45">
							</e-chart-primaryxaxis>

							<e-chart-primaryyaxis interval="2" title="Count">
							</e-chart-primaryyaxis>

							<e-series-collection>
								<e-series type="Column" xName="Driver" yName="Value" dataSource="ViewBag.ChartData"
										  columnWidth="0.7" columnSpacing="0.2">
									<e-series-cornerradius topLeft="8" topRight="8"></e-series-cornerradius>
								</e-series>
							</e-series-collection>

							<e-chart-tooltipsettings enable="true" enableHighlight="true">
							</e-chart-tooltipsettings>

						</ejs-chart>
					</div>
				</div>

			</div>
		</div>
	</div>

	<script id="resourceTemplate" type="text/x-template">
		<div class="template-wrap">
			<div>${resourceData.driver}</div>
			<div>${resourceData.truck}</div>
			<div>${resourceData.capacity}</div>
		</div>
	</script>

	<script id="tooltipTemplate" type="text/x-template">
		<div class="template-wrap">
			<div>Name : ${resourceData.driver}</div>
			<div>Truck : ${resourceData.truck}</div>
			<div>Capacity : ${resourceData.capacity}</div>
		</div>
	</script>

	<script id="headerIndentTemplate" type="text/x-template">
		<div class="template-wrap header-indent">
			<div>Driver</div>
			<div>Truck</div>
			<div>Capacity</div>
		</div>
	</script>
	<script src="~/scripts/chart/theme-color.js"></script>
	<script>
		var driversMaster = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.driversMaster));
		var events = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.events));

		var mode = 'tripcount';

		function load(args) {
            loadChartTheme(args);
        }

		function generateChartData(mode) {

			var scheduleObj = document.getElementById('Schedule').ej2_instances[0];
			var liveEvents = scheduleObj.eventSettings.dataSource || [];

			if (mode === 'capacity') {
				return driversMaster.map(d => ({
					Truck: d.truck,
					Driver: d.driver,
					Value: parseFloat(d.capacity)
				}));
			}

			if (mode === 'tripcount') {
				const m = {};

				liveEvents.forEach(e => {
					const n = driversMaster.find(d => d.id === e.DriverID)?.driver;
					if (n) m[n] = (m[n] || 0) + 1;
				});

				return driversMaster
					.map(d => ({
						Driver: d.driver,
						Value: m[d.driver] || 0
					}))
					.filter(d => d.Value > 0);
			}

			if (mode === 'longest') {
				const totals = {};

				liveEvents.forEach(e => {
					const driverName = driversMaster.find(d => d.id === e.DriverID)?.driver;
					if (!driverName || !e.StartTime || !e.EndTime) return;

					const hours = (new Date(e.EndTime) - new Date(e.StartTime)) / 3600000;
					totals[driverName] = hours;
				});

				return driversMaster
					.map(d => ({
						Driver: d.driver,
						Value: totals[d.driver]
							? Math.round(totals[d.driver] * 100) / 100
							: 0
					}))
					.filter(d => d.Value > 0);


			}

			return [];
		}

		function onModeChange(e) {
			mode = e.value;
			updateChart();
		}

		function onActionComplete(args) {
			if (args.requestType === 'eventCreated' ||
				args.requestType === 'eventChanged' ||
				args.requestType === 'eventRemoved') {
				updateChart();
			}
		}

		function updateChart() {

			var chartObj = document.getElementById('chart').ej2_instances[0];

			if (!chartObj) return;

			const data = generateChartData(mode);

			chartObj.series[0].dataSource = data;

			if (mode === 'capacity') {
				chartObj.series[0].xName = 'Truck';
				chartObj.primaryYAxis.title = 'Capacity (t)';
				chartObj.primaryYAxis.interval = null;
				chartObj.title = 'Truck Capacity';
			} else {
				chartObj.series[0].xName = 'Driver';
				chartObj.primaryYAxis.title =
					mode === 'longest' ? 'Duration (hours)' : 'Count';
				chartObj.primaryYAxis.interval =
					mode === 'tripcount' ? 2 : null;
				chartObj.title =
					mode === 'longest' ? 'Longest Trips' : 'Trip Count';
			}

			chartObj.refresh();
		}

		document.addEventListener("DOMContentLoaded", function () {
			updateChart();
		});


		function onPointRender(args) {

			if (!args.point) return;

			let resource;

			if (mode === 'capacity') {
				resource = driversMaster.find(d => d.truck === args.point.x);
			} else {
				resource = driversMaster.find(d => d.driver === args.point.x);
			}

			if (resource && resource.color) {
				args.fill = resource.color;
			}
		}

		function onTooltipRender(args) {

			const point = args.point;

			if (!point) return;

			let label = point.x;
			let value = point.y;

			if (mode === 'capacity') {
				args.text = `<b>${label}</b><br/>Capacity: ${value} t`;
			}
			else if (mode === 'longest') {
				args.text = `<b>${label}</b><br/>Duration: ${value} hrs`;
			}
			else {
				args.text = `<b>${label}</b><br/>Trips: ${value}`;
			}
		}

	</script>

