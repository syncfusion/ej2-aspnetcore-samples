                    <e-grid-column field="UnitPrice" headerText="Unit Price" width="110" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})" format="C2" textAlign="Right" editType="NumericEdit"></e-grid-column>
                    <e-grid-column field="Discount" headerText="Discount (%)" width="120" edit="@(new { @params = new Syncfusion.EJ2.Inputs.NumericTextBox() { ShowSpinButton= false }})" textAlign="Right" editType="NumericEdit"></e-grid-column>
